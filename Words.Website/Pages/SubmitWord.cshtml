@page "/submit-word"
@model Words.Website.Pages.SubmitWordModel
@{
    ViewData["Title"] = Localizer["submitname-heading"];
}

@using Application.Services.MultiLanguage
@using Words.Website.Resources
@inject Microsoft.Extensions.Localization.IStringLocalizer<Messages> Localizer
@inject ILanguageService LanguageService

@await Html.PartialAsync("Partials/_MiniSearchForm")

<section class="ryt">
    <div class="container">
        <div class="row">
            <div class="col-sm-7">
                <h3>@Localizer["submitname-heading"]</h3>
                <hr />

                @if (Model.SuccessMessage != null)
                {
                    <div class="alert alert-success" role="alert">@Model.SuccessMessage</div>
                }

                @if (Model.ErrorMessage != null)
                {
                    <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
                }

                <form method="post" asp-page="/SubmitWord">
                    @Html.AntiForgeryToken()

                    <div class="response"></div>

                    <div class="form-group">
                        <label class="required" for="word">@Localizer["submitname-entername"]</label>
                        @if (LanguageService.IsYoruba)
                        {
                            <p class="small sec-color">@Localizer["entry-not-found-minikeyb-text"]</p>
                        }
                        <input type="text"
                               class="form-control"
                               id="word"
                               name="word"
                               placeholder="@Localizer["submitname-enternameplch"]"
                               value="@Model.MissingWord"
                               required />
                    </div>
                    <br />

                    <div class="form-group">
                        <label class="required" for="suggestedMeaning">@Localizer["submitname-entermeaning"]:</label>
                        <textarea name="suggestedMeaning" id="suggestedMeaning" class="form-control" rows="3" required></textarea>
                    </div>
                    <br />

                    <div class="form-group">
                        <label class="optional" for="suggestedGeoLocation">@Localizer["submitname-enterlocation"]:</label>
                        <select name="suggestedGeoLocation" id="suggestedGeoLocation" multiple="multiple">
                            @foreach (var geoLocation in Model.GeoLocations)
                            {
                                <option value="@(geoLocation.Region).@(geoLocation.Place)">@geoLocation.Place</option>
                            }
                        </select>
                    </div>
                    <br />

                    <div class="form-group">
                        <label class="required" for="suggestedEmail">@Localizer["submitname-enteremail"]:</label>
                        <input type="email" name="suggestedEmail" class="form-control" id="suggestedEmail" placeholder="Your email" required />
                    </div>

                    <button type="submit" id="submit-word" class="btn btn-success">Submit New Word</button>
                </form>
            </div>
        </div>
    </div>
</section>
